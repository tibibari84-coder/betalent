  APPROVE_VERIFICATION
  REJECT_VERIFICATION
  REVOKE_VERIFICATION
  REQUEST_MORE_INFO
  DISMISS_REPORT
  UPHOLD_REPORT
  CLEAR_VIDEO_FLAGS
}

model ModerationActionLog {
  id             String               @id @default(cuid())
  moderatorId    String
  moderator      User                 @relation(fields: [moderatorId], references: [id], onDelete: Restrict)
  targetType     ModerationTargetType
  targetId       String
  actionType     ModerationActionType
  previousStatus String?
  newStatus      String?
  note           String?
  createdAt      DateTime             @default(now())

  @@index([moderatorId])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}

model ModerationNote {
  id          String               @id @default(cuid())
  moderatorId String
  moderator   User                 @relation(fields: [moderatorId], references: [id], onDelete: Restrict)
  targetType  ModerationTargetType
  targetId    String
  note        String               @db.Text
  createdAt   DateTime             @default(now())

  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Content reporting: fake performance, copyright, authenticity
// ---------------------------------------------------------------------------

enum ContentReportType {
  FAKE_PERFORMANCE // Playback, lip-sync, or non-live performance
  COPYRIGHT // Copyright infringement
  INAPPROPRIATE // Inappropriate content
  OTHER
}

enum ContentReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

/// DB-backed rate limit for login/register. Survives restarts.
model RateLimit {
  prefix     String
  identifier String
  count      Int      @default(0)
  resetAt    DateTime

  @@id([prefix, identifier])
  @@index([resetAt])
}

model ContentReport {
  id         String              @id @default(cuid())
  reporterId String
  reporter   User                @relation("ContentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  videoId    String
  video      Video               @relation(fields: [videoId], references: [id], onDelete: Cascade)
  reportType ContentReportType
  details    String?             @db.Text
  status     ContentReportStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  resolution String?             @db.Text
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([reporterId, videoId, reportType])
  @@index([videoId])
  @@index([status])
  @@index([reportType])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Direct messages (1:1 chat). user1Id < user2Id lexicographically (stable pair key).
// ---------------------------------------------------------------------------

model DmConversation {
  id                 String    @id @default(cuid())
  user1Id            String
  user2Id            String
  user1              User      @relation("DmConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2              User      @relation("DmConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  lastMessageAt      DateTime?
  lastMessagePreview String?   @db.VarChar(500)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  messages           DmMessage[]

  @@unique([user1Id, user2Id])
  @@index([user1Id, lastMessageAt(sort: Desc)])
  @@index([user2Id, lastMessageAt(sort: Desc)])
}

model DmMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   DmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  receiverId     String
  sender         User           @relation("DmMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User           @relation("DmMessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content        String         @db.Text
  isRead         Boolean        @default(false)
  readAt         DateTime?
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([receiverId, isRead])
  @@index([senderId, createdAt])
}
