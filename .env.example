# -----------------------------------------------------------------------------
# BeTalent environment configuration (production-safe documentation)
# -----------------------------------------------------------------------------
#
# This file is documentation for required configuration. Do not rely on
# placeholder values for secrets.
#
# Where to put secrets: project root (same folder as package.json), next to this file.
# - `.env` — shared defaults (often committed as example only; real `.env` may be gitignored)
# - `.env.local` — local overrides; gitignored; use for GOOGLE_* and secrets on your machine
# Next.js loads both; `.env.local` wins if the same key appears in both.
#
# =============================================================================
# `npm run start` WILL FAIL AT BOOT without ALL of:
#   DATABASE_URL, SESSION_SECRET (≥32 chars), AUTH_ENCRYPTION_KEY (32-byte key, base64 or 64 hex)
# Common error: TWO_FACTOR_CRYPTO_NOT_CONFIGURED → add AUTH_ENCRYPTION_KEY to `.env` or `.env.local`:
#   openssl rand -base64 32
# `npm run dev` skips this check (NODE_ENV=development).
# =============================================================================
#
# Sections:
# - Soft MVP (free): required to run upload + processing + vocal scoring + feeds
# - Paid MVP: additional Stripe configuration for paid coin packages
# - Optional / dev-only: tuning knobs
#
# Load testing / observability (optional):
# - `npm run dev` uses NODE_ENV=development. `npm run start` uses NODE_ENV=production — same env rules as Vercel. For k6 against a local prod server, set production secrets below (especially AUTH_ENCRYPTION_KEY + SESSION_SECRET + DATABASE_URL).
# - Set OBSERVE_API_TIMING=1 to emit JSON lines `{ type: "api_timing", route, requestId, status, ms }` on stamped hot routes (stdout; use log aggregation during k6/Locust runs).
# - Responses include `x-request-id` (middleware for /api/* + route stamp). Propagate client header or rely on server-generated id.

# =========================
# Required for Soft MVP
# =========================

# Database connection string for Prisma.
DATABASE_URL=""

# iron-session session secret.
# - PRODUCTION: MUST be set and at least 32 chars. App throws on startup if missing.
# - Generate: openssl rand -base64 32
SESSION_SECRET=""

# `npm run start` / production: set AUTH_ENCRYPTION_KEY too (openssl rand -base64 32). Without it, boot fails with TWO_FACTOR_CRYPTO_NOT_CONFIGURED. Details under "Authentication & email".

# Cron endpoints authorization (used by /api/cron/*).
# These cron routes fail-closed when missing; set when you run cron jobs.
# Vercel: set CRON_SECRET in project env — scheduled jobs call GET with `Authorization: Bearer <CRON_SECRET>`.
# See `vercel.json` for default schedules (rank-talents daily, shares hourly, challenge lifecycle, storage cleanup).
CRON_SECRET=""

# Internal worker authorization for audio analysis endpoints:
# - /api/internal/audio-analysis/pending
# - /api/internal/audio-analysis/result
# - /api/internal/audio-analysis/failed
INTERNAL_AUDIO_ANALYSIS_API_KEY=""

# Object storage (Cloudflare R2; S3-compatible) for:
# - direct video uploads (presigned PUT)
# - thumbnails, avatars, processed audio/video
# All four below are required for upload/complete to work.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Public base URL for playback. STRONGLY RECOMMENDED — without it, /api/videos/upload/complete
# must generate a presigned GET URL (can fail even when PUT succeeded). With this set, completion
# builds a stable public URL string and does not depend on presigning GET.
# R2: enable public access on bucket; use the pub-xxx.r2.dev URL or a custom domain.
# Example: https://pub-d70ce1b202e14716a0440935ff9ac42d.r2.dev
R2_PUBLIC_URL=""

# Audio analysis allowlist (comma-separated hostnames). REQUIRED for videos to become READY.
# Must include the host from R2_PUBLIC_URL (e.g. pub-xxx.r2.dev).
# If missing, enqueue fails and video stays in PROCESSING.
# Example: pub-d70ce1b202e14716a0440935ff9ac42d.r2.dev
AUDIO_ANALYSIS_ALLOWED_DOMAINS=""

# Optional: provide an explicit ffmpeg binary path if it is not on PATH.
# Leave empty if `ffmpeg` is already available in the runtime PATH.
FFMPEG_PATH=""

# Upload completion: if ffmpeg is missing on the server, /api/videos/upload/complete skips
# thumbnail + loudness processing and goes straight to analysis/fallback (otherwise thumbnail.service
# sets PROCESSING_FAILED). Set to 1 to force that path even when ffmpeg exists (debug).
# BETALENT_MINIMAL_MEDIA_PIPELINE="1"
# BETALENT_SKIP_FFMPEG_PIPELINE="1"

# =========================
# Required for Paid MVP
# =========================

# Stripe TEST secret key for checkout session creation and webhook fulfillment.
# TEST MODE ONLY in current BETALENT payments wiring.
STRIPE_SECRET_KEY=""

# Stripe webhook signing secret for /api/webhooks/stripe.
# IMPORTANT:
# - This is NOT your Stripe dashboard API key.
# - For local testing, get this from Stripe CLI:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
#   (copy the printed whsec_... value)
STRIPE_WEBHOOK_SECRET=""

# Stripe TEST publishable key for client UI.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# App URL for Stripe success/cancel redirects (e.g. https://yourdomain.com).
# Production: MUST be set for correct Stripe redirect. Vercel: can use VERCEL_URL as fallback.
# Local test: http://localhost:3000 (required for Stripe Checkout redirects)
NEXT_PUBLIC_APP_URL=""

# =========================
# Authentication & email (registration, verification, Google, 2FA)
# =========================
#
# Public site URL for links in emails and OAuth redirect_uri (no trailing slash).
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
#
# Transactional email — production: set RESEND_API_KEY and/or SENDGRID_API_KEY (tried in that order).
# Without either, registration/verification and password reset cannot deliver in production.
# RESEND_API_KEY=""
# SENDGRID_API_KEY=""
# Sender must be a verified domain/sender in the chosen provider.
# EMAIL_FROM="BeTalent <noreply@yourdomain.com>"
# Inbound address for the public contact form (`POST /api/contact`). Required for contact submissions to be accepted.
# CONTACT_INBOX_EMAIL="support@yourdomain.com"
# AWS SES: use a bridge (e.g. SES SMTP with a provider that exposes SMTP) or add a custom sender; this codebase uses HTTPS APIs only (Resend / SendGrid).
#
# --- Google OAuth (sign-in / sign-up + account linking) — REQUIRED for Google login ---
# In project root `.env` or `.env.local`, add (values from Google Cloud → Credentials → OAuth client):
#
#   GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
#   GOOGLE_CLIENT_SECRET=xxxx
#
# (Quotes optional unless the value has spaces. Same variable names as below.)
#
# Local dev: set the app URL (no trailing slash), then add this EXACT redirect in Google Cloud Console:
#   NEXT_PUBLIC_APP_URL="http://localhost:3000"
#   Authorized redirect URI (copy-paste):
#   http://localhost:3000/api/auth/google/callback
#
# In Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client:
# - Application type: Web application
# - Authorized redirect URIs: must match `{NEXT_PUBLIC_APP_URL}/api/auth/google/callback` exactly.
#   Production example: https://yourdomain.com/api/auth/google/callback
# Set NEXT_PUBLIC_APP_URL (see Authentication section above) so the app builds the same redirect URI.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
#
# AES-256-GCM key for encrypting TOTP secrets at rest. REQUIRED whenever NODE_ENV=production:
# - `npm run start` (production-like server / load testing)
# - Vercel / any production deploy
# Boot fails with TWO_FACTOR_CRYPTO_NOT_CONFIGURED if missing or if the value does not decode to exactly 32 bytes.
# Generate (recommended):
#   openssl rand -base64 32
# Alternative: 64 hex characters representing 32 bytes.
# AUTH_ENCRYPTION_KEY=""
#
# Comma-separated emails that may use legacy passwords (8+ chars, upper/lower/number, no symbol) on change/reset.
# New registrations always require the full policy (symbol included). Default: betalent@gmail.com
# NEXT_PUBLIC_PASSWORD_POLICY_EXEMPT_EMAILS="betalent@gmail.com"

# =========================
# Optional / dev-only tuning
# =========================

# Base path for the Next.js app (used in next.config.mjs).
NEXT_PUBLIC_BASE_PATH=""

# Audio processing tuning (all have safe defaults in code if unset).
AUDIO_PROCESSING_TARGET_LUFS=""
AUDIO_PROCESSING_PEAK_LIMIT_DB=""
AUDIO_PROCESSING_LOUDNESS_RANGE=""
AUDIO_PROCESSING_AAC_BITRATE=""
AUDIO_PROCESSING_ENABLE_DENOISE=""
AUDIO_PROCESSING_TIMEOUT_MS=""
AUDIO_PROCESSING_VERSION=""

# Audio analysis worker tuning (all have safe defaults in code if unset).
AUDIO_ANALYSIS_VERSION=""
AUDIO_ANALYSIS_MAX_RETRIES=""
AUDIO_ANALYSIS_MEDIA_FETCH_TIMEOUT_MS=""
AUDIO_ANALYSIS_FFMPEG_TIMEOUT_MS=""
AUDIO_ANALYSIS_CALLBACK_TIMEOUT_MS=""
AUDIO_ANALYSIS_MAX_DURATION_SEC=""
AUDIO_ANALYSIS_ANALYSIS_TIMEOUT_MS=""
AUDIO_WORKER_POLL_SEC=""

# Internal ops: GET /api/internal/discovery-diagnostics (header X-BT-Discovery-Diagnostics)
DISCOVERY_DIAGNOSTICS_SECRET=""

# Debug only: enable verbose ranking breakdown logs.
DEBUG_RANKING=""
