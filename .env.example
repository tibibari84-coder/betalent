# -----------------------------------------------------------------------------
# BeTalent — variables referenced in this repo (placeholders only).
# Copy to `.env` / `.env.local` and fill in. Do not commit real secrets.
#
# Production boot (`next start` / Vercel): instrumentation requires ALL of:
#   DATABASE_URL
#   SESSION_SECRET   (min 32 chars; not the dev fallback string)
#   AUTH_ENCRYPTION_KEY   (32 bytes: openssl rand -base64 32, or 64 hex chars)
#
# Auto-set by host / Next (do not put in .env unless you override locally):
#   NODE_ENV, NEXT_RUNTIME, VERCEL, VERCEL_ENV, VERCEL_URL, VERCEL_GIT_COMMIT_SHA, CI
# -----------------------------------------------------------------------------

# --- Production boot (see above) ---
DATABASE_URL=""
SESSION_SECRET=""
AUTH_ENCRYPTION_KEY=""

# --- Object storage (R2 / S3-compatible) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# --- Audio analysis worker + allowlist ---
INTERNAL_AUDIO_ANALYSIS_API_KEY=""
AUDIO_ANALYSIS_ALLOWED_DOMAINS=""
AUDIO_ANALYSIS_VERSION=""
AUDIO_ANALYSIS_MAX_RETRIES=""
AUDIO_ANALYSIS_MEDIA_FETCH_TIMEOUT_MS=""
AUDIO_ANALYSIS_FFMPEG_TIMEOUT_MS=""
AUDIO_ANALYSIS_CALLBACK_TIMEOUT_MS=""
AUDIO_ANALYSIS_MAX_DURATION_SEC=""
AUDIO_ANALYSIS_ANALYSIS_TIMEOUT_MS=""
AUDIO_WORKER_POLL_SEC=""

# --- Audio processing (FFmpeg pipeline tuning) ---
AUDIO_PROCESSING_TARGET_LUFS=""
AUDIO_PROCESSING_PEAK_LIMIT_DB=""
AUDIO_PROCESSING_LOUDNESS_RANGE=""
AUDIO_PROCESSING_AAC_BITRATE=""
AUDIO_PROCESSING_ENABLE_DENOISE=""
AUDIO_PROCESSING_TIMEOUT_MS=""
AUDIO_PROCESSING_VERSION=""
FFMPEG_PATH=""

# --- Upload / media pipeline flags ---
BETALENT_MINIMAL_MEDIA_PIPELINE=""
BETALENT_SKIP_FFMPEG_PIPELINE=""

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Public app URL (OAuth, Stripe redirects, emails) ---
NEXT_PUBLIC_APP_URL=""

# --- Next.js ---
NEXT_PUBLIC_BASE_PATH=""

# --- Email ---
RESEND_API_KEY=""
SENDGRID_API_KEY=""
EMAIL_FROM=""
CONTACT_INBOX_EMAIL=""

# --- Auth / policy ---
NEXT_PUBLIC_PASSWORD_POLICY_EXEMPT_EMAILS=""

# --- View tracking ---
VIEW_IP_SALT=""

# --- Internal / ops ---
INTERNAL_JOB_RUNNER_SECRET=""
DISCOVERY_DIAGNOSTICS_SECRET=""
CRON_SECRET=""
BT_OPS_LOG=""
OBSERVE_API_TIMING=""
DEBUG_RANKING=""

# --- Sentry (optional; NEXT_PUBLIC_SENTRY_DSN enables SDK + next.config wrapper) ---
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=""
SENTRY_TRACES_SAMPLE_RATE=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- Client release metadata (optional; often mirrored from server on Vercel) ---
NEXT_PUBLIC_VERCEL_ENV=""
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=""
