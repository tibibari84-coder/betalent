{
  "name": "betalent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --turbo -p 3000",
    "dev:tunnel": "bash scripts/dev-with-tunnel.sh",
    "dev:auto": "while true; do npm run dev || true; sleep 2; echo 'Restarting...'; done",
    "dev:webpack": "next dev -p 3000",
    "dev:clean": "rm -rf .next && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:deploy:neon": "bash scripts/migrate-neon.sh",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed-gifts": "tsx scripts/seed-gifts.ts",
    "job:maintenance": "tsx scripts/run-maintenance-job.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@prisma/client": "^5.0.0",
    "@sentry/nextjs": "^8.55.1",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.10.0",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^12.38.0",
    "iron-session": "^8.0.0",
    "next": "^14.2.0",
    "otplib": "^13.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-simple-maps": "^3.0.0",
    "stripe": "^20.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
